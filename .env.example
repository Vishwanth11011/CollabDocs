# ============================================================
# CollabDocs — Environment Variables
# ============================================================
# Copy to .env and adjust values for your environment.
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://collabdocs:localdev@localhost:5432/collabdocs

# Redis
REDIS_URL=redis://localhost:6379

# Service Ports
COLLAB_PORT=3001
SHORTENER_PORT=3002

# Frontend (Vite env vars must start with VITE_)
VITE_WS_URL=ws://localhost:3001
VITE_API_URL=http://localhost:3002
VITE_APP_URL=http://localhost:5173

# ============================================================
# Production Overrides (uncomment and fill in)
# ============================================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=rediss://default:token@host:6379
